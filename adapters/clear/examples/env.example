# Copy to .env in this folder (never commit .env).

# Judge model (Part A local run and Part B job model)
MODEL_URL=http://127.0.0.1:8000/v1
MODEL_NAME=example-model
# OPENAI_API_KEY=   # only if your OpenAI-compatible server requires it

# Optional: adapter uploads clear_results + HTML when URI and job experiment are set
# MLFLOW_TRACKING_URI=https://your-mlflow.example/

# Part B: Eval Hub HTTPS route, bearer token, tenant (see your cluster docs)
EVALHUB_URL=
EVALHUB_TOKEN=
EVALHUB_TENANT=
NAMESPACE=

# Part B: traces must live in S3 (or compatible); worker downloads them into the job pod
S3_BUCKET=
S3_PREFIX=traces/
S3_SECRET_NAME=
S3_SECRET_NAMESPACE=

# Optional: legacy single string secret_ref + key prefix (some APIs)
# S3_SECRET_REF=

# Optional: red_hat (branded HTML), clear (stock CLEAR). See docs/06-dashboard-theme.md
# CLEAR_DASHBOARD_THEME=red_hat

EXPERIMENT_NAME=clear-agentic-mlflow-exp
# JOB_NAME=clear-evalhub-job-1
